---
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatArticleDate, formatArticleType } from "../lib/format";
import {
  getAllContent,
  getDefaultLatestItems,
  getPinnedFallbackItems,
} from "../lib/posts";

const content = await getAllContent();
const latestItems = [...content].sort((a, b) => b.date.getTime() - a.date.getTime());
const defaultLatestItems = getDefaultLatestItems(content);
const pinnedItems = getPinnedFallbackItems(content);
---

<BaseLayout title="zzlinux | Personal Blog">
  <h1 class="page-title">zzlinux</h1>
  <p class = "lede">拥有向智能上限发起攀登的勇气，</p>
  <p class = "lede">解决更多通往AGI道路上遇到的问题</p>

  <section class="section" aria-labelledby="focus-heading">
    <h2 class="section-label" id="focus-heading">Focus</h2>
    <ul class="tag-list">
      <li class="tag">自动驾驶</li>
      <li class="tag">多模态大模型</li>
      <li class="tag">视频生成</li>
      <li class="tag">强化学习</li>
      <li class="tag">深度学习</li>
      <li class="tag">计算机视觉</li>
    </ul>
  </section>

  <section class="section" aria-labelledby="latest-heading">
    <h2 class="section-label" id="latest-heading">Latest</h2>
    <ul class="article-list" data-latest-list>
      {
        latestItems.map((article, index) => (
          <li class="article-item" data-latest-item hidden={index >= defaultLatestItems.length}>
            <h3>
              <a href={article.href}>{article.title}</a>
            </h3>
            <p class="article-meta">
              <time datetime={article.date.toISOString()}>
                {formatArticleDate(article.date)}
              </time>
              <span>{article.contentType === "paper" ? "Paper" : formatArticleType(article.sourceType)}</span>
              <span>{article.category}</span>
              <span>{article.subcategory}</span>
            </p>
            <p>{article.summary}</p>
          </li>
        ))
      }
    </ul>
    {
      latestItems.length > defaultLatestItems.length && (
        <button class="load-more-button" type="button" data-load-more data-step="5">
          再看 5 篇
        </button>
      )
    }
  </section>

  {
    pinnedItems.length > 0 && (
      <section class="section" aria-labelledby="pinned-heading">
        <h2 class="section-label" id="pinned-heading">Pinned</h2>
        <ul class="article-list">
          {pinnedItems.map((article) => (
            <li class="article-item">
              <h3>
                <a href={article.href}>{article.title}</a>
              </h3>
              <p class="article-meta">
                <time datetime={article.date.toISOString()}>
                  {formatArticleDate(article.date)}
                </time>
                <span>{article.contentType === "paper" ? "Paper" : formatArticleType(article.sourceType)}</span>
                <span>{article.category}</span>
                <span>{article.subcategory}</span>
              </p>
              <p>{article.summary}</p>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <script is:inline>
    const loadMoreButton = document.querySelector("[data-load-more]");
    const latestItems = Array.from(document.querySelectorAll("[data-latest-item]"));

    loadMoreButton?.addEventListener("click", () => {
      const step = Number(loadMoreButton.getAttribute("data-step")) || 5;
      const hiddenItems = latestItems.filter((item) => item.hidden);
      hiddenItems.slice(0, step).forEach((item) => {
        item.hidden = false;
      });

      if (latestItems.every((item) => !item.hidden)) {
        loadMoreButton.hidden = true;
      }
    });
  </script>
</BaseLayout>
