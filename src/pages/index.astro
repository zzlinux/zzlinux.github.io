---
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatArticleDate, formatArticleType } from "../lib/format";
import { getAllArticles } from "../lib/posts";

const articles = (await getAllArticles()).slice(0, 5);
---

<BaseLayout title="zzlinux | Personal Blog">
  <h1 class="page-title">zzlinux</h1>
  <p class="lede">
    研究兴趣包括自动驾驶、多模态大模型、视频生成、强化学习等领域。
  </p>

  <section class="section" aria-labelledby="focus-heading">
    <h2 class="section-label" id="focus-heading">Focus</h2>
    <ul class="tag-list">
      <li class="tag">自动驾驶</li>
      <li class="tag">多模态大模型</li>
      <li class="tag">视频生成</li>
      <li class="tag">强化学习</li>
      <li class="tag">深度学习</li>
      <li class="tag">计算机视觉</li>
    </ul>
  </section>

  <section class="section" aria-labelledby="latest-heading">
    <h2 class="section-label" id="latest-heading">Latest</h2>
    <ul class="article-list">
      {
        articles.map((article) => (
          <li class="article-item">
            <h3>
              <a href={article.href}>{article.title}</a>
            </h3>
            <p class="article-meta">
              <time datetime={article.date.toISOString()}>
                {formatArticleDate(article.date)}
              </time>
              <span>{formatArticleType(article.type)}</span>
            </p>
            <p>{article.summary}</p>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
