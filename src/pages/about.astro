---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | Your Name">
  <h1 class="page-title">About</h1>
  <p class="lede">
    I write about building reliable software, evaluating AI systems, and turning
    research-shaped questions into practical engineering notes.
  </p>

  <section class="section" aria-labelledby="now-heading">
    <h2 class="section-label" id="now-heading">Now</h2>
    <div class="prose">
      <p>
        I am focused on better evaluation workflows, small tools that make
        technical work easier to repeat, and writing that preserves the lessons
        learned while projects are still close at hand.
      </p>
    </div>
  </section>
</BaseLayout>
