---
import "katex/dist/katex.min.css";
import "../styles/global.css";
import { siteConfig } from "../site.config";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "A personal blog for notes, documents, and project writing.",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN" data-theme={siteConfig.theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-shell site-header__inner">
        <a class="site-brand" href="/">zzlinux</a>
        <nav class="site-nav" aria-label="Primary navigation">
          <a href="/">Home</a>
          <a href="/articles/">Articles</a>
          <a href="/papers/">Papers</a>
          <a href="/about/">About</a>
        </nav>
      </div>
    </header>
    <main class="site-shell site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-shell site-footer__inner">
        Built with Astro and GitHub Pages. 内容由 Markdown、HTML 与 PDF 自动汇总。
      </div>
    </footer>
    <script>
      // @ts-nocheck
      const prepareMarkmapBlocks = () => {
        const highlightedBlocks = Array.from(
          document.querySelectorAll("pre[data-language='markmap']"),
        );
        const plaintextBlocks = Array.from(
          document.querySelectorAll("pre[data-language='plaintext']"),
        ).filter((block) => {
          const source = block.textContent?.trim() ?? "";
          const previousHeading = block.previousElementSibling;
          return (
            source.startsWith("# ") &&
            source.includes("\n## ") &&
            previousHeading instanceof HTMLHeadingElement &&
            previousHeading.textContent?.trim() === "论文脑图"
          );
        });
        const languageBlocks = Array.from(
          document.querySelectorAll("code.language-markmap"),
          (code) => code.closest("pre"),
        ).filter(Boolean);
        const blocks = [...new Set([...highlightedBlocks, ...plaintextBlocks, ...languageBlocks])];

        for (const block of blocks) {
          if (!(block instanceof HTMLElement) || block.dataset.markmapPrepared === "true") {
            continue;
          }

          const source = block.textContent?.trim();
          if (!source) continue;

          const shell = document.createElement("div");
          shell.className = "markmap-shell";
          shell.dataset.markmapSource = source;

          const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
          svg.classList.add("markmap-svg");
          svg.setAttribute("role", "img");
          svg.setAttribute("aria-label", "论文脑图");

          shell.append(svg);
          block.dataset.markmapPrepared = "true";
          block.replaceWith(shell);
        }
      };

      const renderMarkmaps = async () => {
        prepareMarkmapBlocks();

        const shells = Array.from(document.querySelectorAll("[data-markmap-source]"));

        if (shells.length === 0) return;

        const namespace = "http://www.w3.org/2000/svg";
        const xGap = 176;
        const yGap = 28;
        const rootWidth = 132;
        const branchWidth = 104;
        const leafWidth = 220;

        const createSvgElement = (tag, attributes = {}) => {
          const element = document.createElementNS(namespace, tag);
          for (const [key, value] of Object.entries(attributes)) {
            element.setAttribute(key, String(value));
          }
          return element;
        };

        const parseSource = (source) => {
          const root = { id: "0", text: "脑图", depth: 0, children: [] };
          const stack = [root];

          source.split("\n").forEach((line) => {
            const match = /^(#{1,6})\s+(.+?)\s*$/.exec(line);
            if (!match) return;

            const depth = match[1].length;
            const text = match[2].replace(/`/g, "").trim();
            if (!text) return;

            while (stack.length > 1 && stack[stack.length - 1].depth >= depth) {
              stack.pop();
            }

            const parent = stack[stack.length - 1];
            const node = {
              id: `${parent.id}.${parent.children.length}`,
              text,
              depth,
              children: [],
            };
            parent.children.push(node);
            stack.push(node);
          });

          return root.children.length === 1 ? root.children[0] : root;
        };

        const getNodeWidth = (node, depth) => {
          if (depth === 0) return rootWidth;
          if (node.children.length > 0) return branchWidth;
          return leafWidth;
        };

        const wrapText = (text, maxLength = 18) => {
          const words = text.includes(" ") ? text.split(/\s+/) : Array.from(text);
          const lines = [];
          let current = "";

          for (const word of words) {
            const separator = text.includes(" ") && current ? " " : "";
            const next = `${current}${separator}${word}`;
            if (next.length > maxLength && current) {
              lines.push(current);
              current = word;
            } else {
              current = next;
            }
          }

          if (current) lines.push(current);
          return lines.slice(0, 3);
        };

        const getVisibleLayout = (root, collapsed) => {
          let cursor = 0;
          let maxDepth = 0;
          const visible = [];
          const links = [];

          const layout = (node, depth, parent = null) => {
            const hasChildren = node.children.length > 0;
            const width = getNodeWidth(node, depth);
            const lines = wrapText(node.text, depth === 0 ? 14 : hasChildren ? 8 : 22);
            const height = (depth === 0 ? 34 : hasChildren ? 26 : 22)
              + Math.max(0, lines.length - 1) * 15;
            const item = {
              ...node,
              depth,
              height,
              lines,
              width,
              x: depth * xGap,
              y: 0,
              hasChildren,
            };

            visible.push(item);
            maxDepth = Math.max(maxDepth, depth);

            if (parent) links.push({ source: parent, target: item });

            if (item.hasChildren && !collapsed.has(node.id)) {
              const childItems = node.children.map((child) => layout(child, depth + 1, item));
              item.y = (childItems[0].y + childItems[childItems.length - 1].y) / 2;
            } else {
              item.y = cursor;
              cursor += Math.max(yGap, item.height + 7);
            }

            return item;
          };

          layout(root, 0);

          const minY = Math.min(...visible.map((node) => node.y - node.height / 2));
          if (minY < 0) {
            visible.forEach((node) => {
              node.y -= minY;
            });
          }

          return {
            visible,
            links,
            width: maxDepth * xGap + leafWidth + 24,
            height: Math.max(...visible.map((node) => node.y + node.height / 2)) + 18,
          };
        };

        const colorForDepth = (depth) => {
          const colors = ["#2f6f73", "#5baee8", "#8f7cf5", "#32b99a", "#a78bfa"];
          return colors[depth % colors.length];
        };

        const branchColor = (node) => {
          const firstLevel = node.id.split(".")[1] ?? "0";
          const colors = ["#5baee8", "#8f7cf5", "#32b99a", "#7ab6ff", "#a78bfa", "#d5b76f"];
          return colors[Number(firstLevel) % colors.length];
        };

        const renderTree = (shell, svg, root, collapsed) => {
          svg.replaceChildren();
          const layout = getVisibleLayout(root, collapsed);
          svg.setAttribute("viewBox", `0 0 ${layout.width} ${layout.height}`);
          svg.setAttribute("width", String(layout.width));
          svg.setAttribute("height", String(layout.height));
          const group = createSvgElement("g", { class: "markmap-viewport" });
          svg.append(group);

          for (const link of layout.links) {
            const sourceX = link.source.x + link.source.width;
            const sourceY = link.source.y;
            const targetX = link.target.x;
            const targetY = link.target.y;
            const turnX = sourceX + Math.max(22, (targetX - sourceX) * 0.34);
            group.append(
              createSvgElement("path", {
                class: `markmap-link depth-${link.target.depth}`,
                d: `M${sourceX},${sourceY} H${turnX} V${targetY} H${targetX}`,
                stroke: branchColor(link.target),
              }),
            );
          }

          for (const node of layout.visible) {
            const nodeGroup = createSvgElement("g", {
              class: [
                "markmap-node",
                `depth-${node.depth}`,
                node.hasChildren ? "has-children" : "is-leaf",
                collapsed.has(node.id) ? "is-collapsed" : "",
              ].filter(Boolean).join(" "),
              transform: `translate(${node.x},${node.y - node.height / 2})`,
            });
            nodeGroup.dataset.nodeId = node.id;

            if (node.depth === 0 || node.hasChildren) {
              const rect = createSvgElement("rect", {
                width: node.width,
                height: node.height,
                rx: node.depth === 0 ? 6 : 5,
                fill: node.depth === 0 ? "#1f1f1f" : "#eef7f7",
                stroke: node.depth === 0 ? "#1f1f1f" : "#4b5563",
                "stroke-width": node.depth === 0 ? 0 : 1.5,
              });
              nodeGroup.append(rect);
            } else {
              nodeGroup.append(
                createSvgElement("line", {
                  class: "markmap-leaf-stem",
                  x1: 0,
                  x2: 32,
                  y1: node.height / 2,
                  y2: node.height / 2,
                  stroke: branchColor(node),
                }),
              );
            }

            node.lines.forEach((line, index) => {
              const text = createSvgElement("text", {
                x: node.depth === 0 || node.hasChildren ? 10 : 50,
                y: node.depth === 0 ? 22 + index * 15 : node.hasChildren ? 17 + index * 15 : 16 + index * 15,
              });
              text.textContent = line;
              nodeGroup.append(text);
            });

            if (node.hasChildren) {
              const folded = collapsed.has(node.id);
              const toggle = createSvgElement("g", {
                class: "markmap-toggle",
                transform: `translate(${node.width - 8},${node.height / 2})`,
              });
              toggle.append(createSvgElement("circle", { r: 5 }));
              const toggleText = createSvgElement("text", { y: 3, "text-anchor": "middle" });
              toggleText.textContent = folded ? "+" : "−";
              toggle.append(toggleText);
              nodeGroup.append(toggle);
            }

            nodeGroup.addEventListener("click", () => {
              if (!node.hasChildren) return;
              if (collapsed.has(node.id)) collapsed.delete(node.id);
              else collapsed.add(node.id);
              renderTree(shell, svg, root, collapsed);
            });

            group.append(nodeGroup);
          }
        };

        for (const shell of shells) {
          if (!(shell instanceof HTMLElement) || shell.dataset.rendered === "true") {
            continue;
          }

          const source = shell.dataset.markmapSource?.trim();
          if (!source) continue;

          const svg = shell.querySelector("svg");
          if (!(svg instanceof SVGElement)) continue;

          try {
            const root = parseSource(source);
            const collapsed = new Set();

            shell.dataset.rendered = "true";
            shell.classList.add("is-rendered");
            renderTree(shell, svg, root, collapsed);
          } catch (error) {
            shell.dataset.rendered = "error";
            shell.classList.add("has-render-error");
            console.error("Failed to render Markmap diagram", error);
          }
        }
      };

      renderMarkmaps();
    </script>
  </body>
</html>
